# ──────────────────────────────────────────────────────────────────────────────
# mastra-orquestador — Variables de entorno
# Copia este archivo a .env y completa los valores
#
# NOTA: GitHub Copilot actúa como CLIENTE que llama las tools MCP.
# Los agentes Mastra internos necesitan su propia API Key para generar respuestas.
# ──────────────────────────────────────────────────────────────────────────────

# ── Proveedor de IA ────────────────────────────────────────────────────────────
# Opciones: openai | anthropic | google | groq | ollama
# Por defecto (si se omite): openai
AI_PROVIDER=groq

# Modelo a usar (si se omite, se usa el modelo por defecto del proveedor)
# groq:      llama-3.3-70b-versatile | llama3-70b-8192 | mixtral-8x7b-32768
# google:    gemini-2.0-flash | gemini-1.5-pro
# openai:    gpt-4o | gpt-4o-mini
# anthropic: claude-3-5-sonnet-20241022 | claude-3-haiku-20240307
# ollama:    llama3.2 | mistral | codellama
AI_MODEL=llama-3.3-70b-versatile

# ── Opción 1 (RECOMENDADA — GRATIS): Groq ─────────────────────────────────────
# Obtén tu API Key gratis en: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ── Opción 2 (GRATIS): Google Gemini ──────────────────────────────────────────
# Obtén tu API Key gratis en: https://aistudio.google.com/app/apikey
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...
# AI_PROVIDER=google
# AI_MODEL=gemini-2.0-flash

# ── Opción 3 (LOCAL — SIN API KEY): Ollama ────────────────────────────────────
# Instala Ollama: brew install ollama && ollama pull llama3.2
# AI_PROVIDER=ollama
# AI_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# ── Opción 4 (DE PAGO): OpenAI ────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o

# ── Opción 5 (DE PAGO): Anthropic ─────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# AI_PROVIDER=anthropic
# AI_MODEL=claude-3-5-sonnet-20241022

# ── Integraciones opcionales ───────────────────────────────────────────────────

# Token de acceso de Figma (para integración con Figma API)
FIGMA_ACCESS_TOKEN=

# SonarQube (solo si usas el agente de seguridad con servidor propio)
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=
