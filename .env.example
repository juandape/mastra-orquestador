# ──────────────────────────────────────────────────────────────────────────────
# mastra-orquestador — Variables de entorno
# Copia este archivo a .env y completa los valores
# ──────────────────────────────────────────────────────────────────────────────

# [REQUERIDO] API Key de OpenAI
OPENAI_API_KEY=sk-...

# [OPCIONAL] Modelo de OpenAI a usar (por defecto: gpt-4o)
# Opciones recomendadas: gpt-4o | gpt-4o-mini | gpt-4-turbo
OPENAI_MODEL=gpt-4o

# [OPCIONAL] Token de acceso de Figma (para integración con Figma API)
FIGMA_ACCESS_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# SonarQube (opcional — solo si usas el agente de seguridad con servidor propio)
# ──────────────────────────────────────────────────────────────────────────────
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=

# ──────────────────────────────────────────────────────────────────────────────
# Google Analytics (opcional — reemplaza GA_MEASUREMENT_ID en tu proyecto)
# ──────────────────────────────────────────────────────────────────────────────
# GA_MEASUREMENT_ID=G-XXXXXXXXXX
