{
  "name": "hu-orquestador",
  "version": "1.0.0",
  "description": "Orquestador de agentes IA con Mastra para proyectos React/React Native — uso vía MCP con GitHub Copilot",
  "type": "module",
  "scripts": {
    "setup": "node scripts/setup.js",
    "doctor": "node scripts/doctor.js",
    "mcp": "tsx src/mcp-server.ts",
    "build": "tsc --project tsconfig.json",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "mastra",
    "orquestador",
    "react",
    "react-native",
    "agentes",
    "ia"
  ],
  "author": "Juan Peña <juandavidp76@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juandape/mastra-orquestador.git"
  },
  "homepage": "https://github.com/juandape/mastra-orquestador#readme",
  "bugs": {
    "url": "https://github.com/juandape/mastra-orquestador/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/groq": "^3.0.29",
    "@ai-sdk/openai": "^3.0.41",
    "@mastra/core": "^1.13.2",
    "@mastra/libsql": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "ollama-ai-provider": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
