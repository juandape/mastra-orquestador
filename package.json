  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.53",
    "@ai-sdk/google": "^3.0.36",
    "@ai-sdk/groq": "^3.0.27",
    "@ai-sdk/openai": "^1.1.9",
    "@mastra/core": "^0.7.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.6.0",
